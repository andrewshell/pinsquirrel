{
  "name": "@pinsquirrel/services",
  "version": "1.0.0",
  "description": "Business logic services and validation for PinSquirrel",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "test": "vitest --run",
    "test:watch": "vitest --watch --coverage",
    "test:coverage": "vitest --run --coverage"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.39.4",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@pinsquirrel/domain": "workspace:*",
    "zod": "^4.3.6"
  }
}
