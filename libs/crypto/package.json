{
  "name": "@pinsquirrel/crypto",
  "version": "1.0.0",
  "description": "Email sealing and key management crypto for PinSquirrel",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "test": "vitest --run",
    "test:watch": "vitest --watch --coverage",
    "test:coverage": "vitest --run --coverage",
    "keygen": "tsx src/keygen.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10",
    "@types/node": "^24.12.2",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
